{
  "name": "agentart",
  "version": "1.5.6",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vercel-labs/agentart.git"
  },
  "devDependencies": {
    "@clack/prompts": "^0.11.0",
    "@types/bun": "1.3.13",
    "@types/node": "^22.10.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  },
  "bugs": {
    "url": "https://github.com/vercel-labs/agentart/issues"
  },
  "description": "Agentart: the open agent skills ecosystem",
  "homepage": "https://github.com/vercel-labs/agentart#readme",
  "keywords": [
    "cli",
    "agent-skills",
    "agentart",
    "ai-agents",
    "aider-desk",
    "amp",
    "antigravity",
    "augment",
    "bob",
    "claude-code",
    "openclaw",
    "cline",
    "codearts-agent",
    "codebuddy",
    "codemaker",
    "codestudio",
    "codex",
    "command-code",
    "continue",
    "cortex",
    "crush",
    "cursor",
    "deepagents",
    "devin",
    "dexto",
    "droid",
    "firebender",
    "forgecode",
    "gemini-cli",
    "github-copilot",
    "goose",
    "hermes-agent",
    "junie",
    "iflow-cli",
    "kilo",
    "kimi-cli",
    "kiro-cli",
    "kode",
    "mcpjam",
    "mistral-vibe",
    "mux",
    "opencode",
    "openhands",
    "pi",
    "qoder",
    "qwen-code",
    "replit",
    "rovodev",
    "roo",
    "tabnine-cli",
    "trae",
    "trae-cn",
    "warp",
    "windsurf",
    "zencoder",
    "neovate",
    "pochi",
    "adal",
    "universal"
  ],
  "license": "MIT",
  "lint-staged": {
    "src/**/*.ts": "prettier --write",
    "scripts/**/*.ts": "prettier --write",
    "tests/**/*.ts": "prettier --write"
  },
  "packageManager": "bun@1.3.13",
  "private": true,
  "scripts": {
    "build": "bun run scripts/build-binary.ts",
    "build:release": "bun run scripts/build-binaries.ts",
    "dev": "bun src/cli.ts",
    "exec:test": "bun scripts/execute-tests.ts",
    "format": "prettier --write \"{src,scripts,tests}/**/*.ts\" \"*.md\" \"skills/**/*.md\" \".github/**/*.yml\" \"package.json\"",
    "format:check": "prettier --check \"{src,scripts,tests}/**/*.ts\" \"*.md\" \"skills/**/*.md\" \".github/**/*.yml\" \"package.json\"",
    "prepare": "husky",
    "test": "vitest",
    "type-check": "tsc --noEmit",
    "validate:agents": "bun scripts/validate-agents.ts",
    "sync:agents": "bun scripts/sync-agents.ts"
  },
  "type": "module"
}
